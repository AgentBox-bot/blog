<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>流体诗意 | 个人艺术场</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Montserrat:wght@200;300;400&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #030305;
            --text-main: #f5f5f7;
            --text-muted: rgba(245, 245, 247, 0.6);
            --accent-1: #4a00e0;
            --accent-2: #00e5ff;
            --glass-bg: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
        }

        /* 基础重置 */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body, html {
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
            cursor: none; /* 隐藏默认光标 */
            scroll-behavior: smooth;
        }

        /* 噪点纹理层 - 增加电影感 */
        .noise-overlay {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            pointer-events: none; z-index: 9999; opacity: 0.05;
            background-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"><filter id="noiseFilter"><feTurbulence type="fractalNoise" baseFrequency="0.75" numOctaves="3" stitchTiles="stitch"/></filter><rect width="100%" height="100%" filter="url(%23noiseFilter)"/></svg>');
        }

        /* 自定义光标 */
        .cursor-dot, .cursor-ring {
            position: fixed; top: 0; left: 0; transform: translate(-50%, -50%);
            border-radius: 50%; pointer-events: none; z-index: 10000;
        }
        .cursor-dot {
            width: 6px; height: 6px; background-color: var(--text-main);
        }
        .cursor-ring {
            width: 40px; height: 40px; border: 1px solid var(--text-muted);
            transition: transform 0.15s ease-out, width 0.3s, height 0.3s, border-color 0.3s;
        }

        /* 背景流体极光 */
        .orb {
            position: fixed; border-radius: 50%; filter: blur(120px);
            z-index: 0; opacity: 0.5; animation: float 20s infinite ease-in-out alternate;
        }
        .orb-1 {
            width: 50vw; height: 50vw; background: var(--accent-1);
            top: -20%; left: -10%;
        }
        .orb-2 {
            width: 40vw; height: 40vw; background: var(--accent-2);
            bottom: -10%; right: -10%; animation-delay: -5s;
        }

        /* 页面布局容器 */
        .container {
            position: relative; z-index: 1; max-width: 1400px;
            margin: 0 auto; padding: 0 5vw;
        }

        /* 极简导航栏 */
        nav {
            display: flex; justify-content: space-between; align-items: center;
            padding: 4vh 0; font-size: 0.8rem; letter-spacing: 2px; text-transform: uppercase;
        }
        .logo { font-weight: 400; letter-spacing: 4px; }
        .menu-btn { cursor: none; text-decoration: none; color: var(--text-main); position: relative; }
        .menu-btn::after {
            content: ''; position: absolute; bottom: -4px; left: 0;
            width: 0%; height: 1px; background: var(--text-main); transition: width 0.3s;
        }
        .menu-btn:hover::after { width: 100%; }

        /* 英雄区域 (Hero Section) */
        .hero {
            height: 80vh; display: flex; flex-direction: column;
            justify-content: center; align-items: flex-start;
        }
        .hero h1 {
            font-family: 'Cormorant Garamond', serif; font-size: clamp(4rem, 10vw, 8rem);
            font-weight: 300; line-height: 1; margin-bottom: 20px;
            background: linear-gradient(to right, #fff, rgba(255,255,255,0.3));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        .hero p {
            font-size: 1rem; color: var(--text-muted); font-weight: 300;
            letter-spacing: 1px; max-width: 400px; line-height: 1.8;
        }
        .scroll-indicator {
            position: absolute; bottom: 5vh; left: 5vw; display: flex; align-items: center; gap: 15px;
            font-size: 0.7rem; letter-spacing: 3px; color: var(--text-muted);
        }
        .scroll-line {
            width: 1px; height: 50px; background: rgba(255,255,255,0.2); position: relative; overflow: hidden;
        }
        .scroll-line::before {
            content: ''; position: absolute; top: -100%; left: 0; width: 100%; height: 100%;
            background: var(--text-main); animation: scroll-down 2s infinite cubic-bezier(0.77, 0, 0.175, 1);
        }

        /* 碎片区 (文章列表) - 非传统非对称布局 */
        .journal {
            display: flex; flex-direction: column; padding: 10vh 0 20vh 0; gap: 15vh;
        }
        .fragment {
            width: 55%; padding: 4rem; position: relative;
            background: var(--glass-bg); backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border); border-radius: 24px;
            transform-style: preserve-3d; transition: opacity 0.8s ease, transform 0.8s ease;
            opacity: 0; transform: translateY(100px); /* 初始隐藏，等待JS触发 */
        }
        .fragment.visible { opacity: 1; transform: translateY(0); }
        
        .fragment:nth-child(even) { align-self: flex-end; }
        .fragment:nth-child(odd) { align-self: flex-start; }

        .fragment-meta {
            font-size: 0.75rem; color: var(--accent-2); letter-spacing: 2px;
            margin-bottom: 1.5rem; display: block; text-transform: uppercase;
        }
        .fragment h2 {
            font-family: 'Cormorant Garamond', serif; font-size: 3rem; font-weight: 300;
            margin-bottom: 1.5rem; line-height: 1.1; transition: transform 0.3s ease;
        }
        .fragment p {
            color: var(--text-muted); line-height: 1.8; font-size: 0.95rem; font-weight: 300;
        }
        .fragment-link {
            display: inline-block; margin-top: 2.5rem; text-decoration: none;
            color: var(--text-main); font-size: 0.8rem; letter-spacing: 2px;
            text-transform: uppercase; border-bottom: 1px solid var(--text-muted);
            padding-bottom: 5px; transition: color 0.3s, border-color 0.3s;
            cursor: none;
        }

        /* 动画定义 */
        @keyframes float {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(10vw, -10vh) scale(1.1); }
        }
        @keyframes scroll-down {
            0% { top: -100%; }
            100% { top: 100%; }
        }

        /* 响应式设计 */
        @media (max-width: 900px) {
            .fragment { width: 85%; padding: 2.5rem; align-self: center !important; }
            .hero h1 { font-size: 3.5rem; }
            .orb { opacity: 0.3; } /* 移动端降低光晕强度以免干扰阅读 */
            .cursor-dot, .cursor-ring { display: none; } /* 移动端不显示光标 */
            body, html { cursor: auto; }
            .menu-btn, .fragment-link { cursor: pointer; }
        }
    </style>
</head>
<body>

    <!-- 视觉层 -->
    <div class="noise-overlay"></div>
    <div class="cursor-dot"></div>
    <div class="cursor-ring"></div>
    
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <!-- 内容层 -->
    <div class="container">
        <nav>
            <div class="logo">Ethereal.</div>
            <a href="#" class="menu-btn interactive">探索 / Explore</a>
        </nav>

        <section class="hero">
            <h1>Fluid<br>Poetics.</h1>
            <p>在这个碎片化的数字纪元，我捕捉那些转瞬即逝的思绪，将其凝固为深空中的发光体。</p>
            <div class="scroll-indicator">
                <span>SCROLL</span>
                <div class="scroll-line"></div>
            </div>
        </section>

        <section class="journal">
            <!-- 碎片 1 -->
            <article class="fragment interactive-card">
                <span class="fragment-meta">Chapter I — 视觉探索</span>
                <h2>The Shape of Silence<br>无形的几何</h2>
                <p>当设计褪去所有冗余的装饰，留下的便是空间与光影的低语。在这篇文章中，我探讨了如何用最少的元素表达最深邃的情感，让空白成为画布的主角。</p>
                <a href="#" class="fragment-link interactive">阅读记忆</a>
            </article>

            <!-- 碎片 2 -->
            <article class="fragment interactive-card">
                <span class="fragment-meta">Chapter II — 技术诗学</span>
                <h2>Echoes in Algorithms<br>代码的回声</h2>
                <p>算法不仅是冷冰冰的逻辑判断，它们是控制论时代的诗歌。探讨前端动效背后的数学之美，以及如何赋予像素以灵魂与呼吸感。</p>
                <a href="#" class="fragment-link interactive">阅读记忆</a>
            </article>

            <!-- 碎片 3 -->
            <article class="fragment interactive-card">
                <span class="fragment-meta">Chapter III — 生活哲学</span>
                <h2>Liquid Modernity<br>液态生活</h2>
                <p>鲍曼笔下的“液态现代性”正在重塑我们的感知。在不断流动的世界里，如何寻找个人的坐标轴？这是关于在混沌中保持清醒的思考。</p>
                <a href="#" class="fragment-link interactive">阅读记忆</a>
            </article>
        </section>
    </div>

    <script>
        // 1. 自定义平滑光标与交互反馈
        const cursorDot = document.querySelector('.cursor-dot');
        const cursorRing = document.querySelector('.cursor-ring');
        let mouseX = 0, mouseY = 0;
        let ringX = 0, ringY = 0;

        document.addEventListener('mousemove', (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
            
            // 点立即跟随
            cursorDot.style.transform = `translate3d(${mouseX}px, ${mouseY}px, 0) translate(-50%, -50%)`;
        });

        // 利用 requestAnimationFrame 让外环产生平滑的延迟追随效果
        function animateCursor() {
            let distX = mouseX - ringX;
            let distY = mouseY - ringY;
            ringX += distX * 0.15; // 缓动系数
            ringY += distY * 0.15;
            
            cursorRing.style.transform = `translate3d(${ringX}px, ${ringY}px, 0) translate(-50%, -50%)`;
            requestAnimationFrame(animateCursor);
        }
        animateCursor();

        // 交互元素的悬停特效
        const interactives = document.querySelectorAll('.interactive');
        interactives.forEach(el => {
            el.addEventListener('mouseenter', () => {
                cursorRing.style.width = '60px';
                cursorRing.style.height = '60px';
                cursorRing.style.borderColor = 'var(--accent-2)';
                cursorRing.style.backgroundColor = 'rgba(0, 229, 255, 0.1)';
            });
            el.addEventListener('mouseleave', () => {
                cursorRing.style.width = '40px';
                cursorRing.style.height = '40px';
                cursorRing.style.borderColor = 'var(--text-muted)';
                cursorRing.style.backgroundColor = 'transparent';
            });
        });

        // 2. 文章卡片的 3D 偏转动效 (磁性效果)
        const cards = document.querySelectorAll('.interactive-card');
        cards.forEach(card => {
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                // 计算偏转角度 (中心为0)
                const rotateX = ((y / rect.height) - 0.5) * -8;
                const rotateY = ((x / rect.width) - 0.5) * 8;
                
                card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
                
                // 让标题产生视觉视差
                const title = card.querySelector('h2');
                title.style.transform = `translateZ(30px) translateX(${rotateY * 0.5}px) translateY(${rotateX * -0.5}px)`;
            });

            card.addEventListener('mouseleave', () => {
                card.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
                const title = card.querySelector('h2');
                title.style.transform = `translateZ(0) translateX(0) translateY(0)`;
            });
            
            // 绑定光标悬停样式
            card.addEventListener('mouseenter', () => {
                cursorRing.style.width = '80px';
                cursorRing.style.height = '80px';
                cursorRing.style.borderColor = 'transparent';
                cursorRing.style.backdropFilter = 'invert(100%)';
            });
            card.addEventListener('mouseleave', () => {
                cursorRing.style.width = '40px';
                cursorRing.style.height = '40px';
                cursorRing.style.borderColor = 'var(--text-muted)';
                cursorRing.style.backdropFilter = 'none';
            });
        });

        // 3. 滚动浮现动效 (Intersection Observer)
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.15
        };

        const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    observer.unobserve(entry.target); // 动画只触发一次
                }
            });
        }, observerOptions);

        cards.forEach(card => {
            observer.observe(card);
        });
    </script>
</body>
</html>
